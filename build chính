<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zeburrger | Zeka Project 2026</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #FDFBF7; }
        [x-cloak] { display: none !important; }
        .circle-progress { transition: stroke-dashoffset 1.5s ease-out; }
    </style>
</head>
<body x-data="zekaApp()">

    <div class="max-w-6xl mx-auto px-4 py-8 md:py-12 space-y-12">
        <header class="flex justify-between items-center border-b-2 border-black pb-6">
            <div class="flex items-center gap-3">
                <img src="logo.png" alt="Logo" class="w-12 h-12 rounded-full border-2 border-orange-600 object-cover shadow-sm">
                <h1 class="text-3xl font-black italic uppercase text-orange-600 tracking-tighter">ZEBURRGER</h1>
            </div>
            <nav class="hidden md:flex gap-6 font-bold uppercase text-[10px] tracking-[0.2em]">
                <a href="#" class="hover:text-orange-600 transition">Timeline</a>
                <a href="https://quy.momo.vn/v2/XjLc4Rvcl5?e14fe" target="_blank" class="hover:text-orange-600 transition">Quỹ Donate</a>
                <a href="https://www.threads.com/@zeburger4zeka" target="_blank" class="bg-black text-white px-5 py-2 rounded-full hover:bg-orange-600 transition">Fanpage</a>
            </nav>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <section class="bg-white p-8 rounded-[2.5rem] shadow-xl border-2 border-black flex flex-col justify-between min-h-[420px]">
                <div>
                    <div class="flex justify-between items-center mb-8">
                        <h2 class="text-2xl font-extrabold uppercase italic flex items-center gap-2">
                            <span class="w-2 h-8 bg-orange-500 rounded-full"></span> Thông báo
                        </h2>
                        <div class="flex gap-2">
                            <button @click="prev()" class="p-3 border-2 border-black rounded-full hover:bg-orange-600 hover:text-white transition">←</button>
                            <button @click="next()" class="p-3 border-2 border-black rounded-full hover:bg-orange-600 hover:text-white transition">→</button>
                        </div>
                    </div>
                    <div @click="openModal()" class="group cursor-pointer bg-orange-50/50 p-6 rounded-3xl border-2 border-dashed border-orange-300 hover:border-black transition-all duration-300">
                        <span class="text-orange-600 font-bold text-sm" x-text="posts[index].date"></span>
                        <h3 class="text-2xl font-black my-3 group-hover:text-orange-600 transition" x-text="posts[index].title"></h3>
                        <p class="text-gray-500 line-clamp-2 leading-relaxed" x-text="posts[index].content"></p>
                        <div class="mt-4 flex items-center gap-2 text-orange-600 font-bold text-xs uppercase italic">Xem chi tiết báo cáo ↗</div>
                    </div>
                </div>
            </section>

            <section class="bg-orange-600 p-10 rounded-[2.5rem] shadow-xl text-white flex flex-col md:flex-row items-center gap-8 relative overflow-hidden">
                <div class="relative w-40 h-40 flex-shrink-0">
                    <svg class="w-full h-full -rotate-90" viewBox="0 0 100 100">
                        <circle cx="50" cy="50" r="42" stroke="rgba(255,255,255,0.2)" stroke-width="10" fill="transparent" />
                        <circle cx="50" cy="50" r="42" stroke="white" stroke-width="10" fill="transparent"
                                stroke-dasharray="263.8" :stroke-dashoffset="263.8 - (263.8 * 100) / 100" class="circle-progress" stroke-linecap="round" />
                    </svg>
                    <div class="absolute inset-0 flex flex-col items-center justify-center font-black italic">100%</div>
                </div>
                <div class="z-10 text-center md:text-left">
                    <h2 class="text-lg font-bold opacity-80 uppercase tracking-widest italic mb-2">Tổng quỹ khả dụng (T2)</h2>
                    <div class="text-5xl md:text-6xl font-black italic tracking-tighter mb-4">
                        <span x-text="fundDisplay.toLocaleString()"></span> <span class="text-xl not-italic font-bold">VNĐ</span>
                    </div>
                    <p class="text-orange-100 text-sm italic">"Tích lũy chuẩn bị cho kỷ niệm 6 năm Debut vào tháng 3."</p>
                </div>
            </section>
        </div>

        <section class="grid grid-cols-1 lg:grid-cols-3 gap-8 pb-10">
            <div class="lg:col-span-2 aspect-video bg-gray-200 rounded-[3rem] overflow-hidden relative group shadow-2xl border-4 border-white">
                <img src="logo.jpg" class="absolute inset-0 w-full h-full object-cover opacity-20 blur-sm">
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <a href="https://www.threads.com/@zeburger4zeka/post/DUDv6Edj2C2" target="_blank" class="bg-white p-6 rounded-full shadow-2xl hover:scale-110 transition">▶</a>
                    <p class="mt-4 font-black bg-white/80 px-4 py-1 rounded-full text-[10px] tracking-widest">XEM VIDEO TRÊN THREADS</p>
                </div>
            </div>
            <div class="bg-[#E5E7EB] p-10 rounded-[3rem] flex flex-col items-center justify-center text-center border-4 border-white shadow-xl relative overflow-hidden group">
                <div class="bg-white p-3 rounded-3xl mb-6 border-2 border-black rotate-2 group-hover:rotate-0 transition-transform duration-500 w-48 h-48 shadow-lg">
                    <img src="qr.png" alt="QR MoMo" class="w-full h-full object-contain">
                </div>
                <a href="https://quy.momo.vn/v2/XjLc4Rvcl5?e14fe" target="_blank" class="w-full py-4 bg-orange-600 text-white rounded-2xl font-black text-sm hover:bg-black transition-all shadow-lg tracking-widest">THAM GIA QUỸ</a>
            </div>
        </section>
    </div>

    <div x-show="showModal" x-cloak class="fixed inset-0 bg-black/90 backdrop-blur-md z-50 flex items-center justify-center p-4">
        <div class="bg-white p-8 md:p-12 rounded-[3.5rem] max-w-2xl w-full relative shadow-2xl border-t-8 border-orange-600" @click.away="showModal = false">
            <button @click="showModal = false" class="absolute top-8 right-8 p-2 hover:bg-gray-100 rounded-full border border-gray-200 text-2xl">✕</button>
            <span class="text-orange-600 font-black italic tracking-widest text-sm" x-text="posts[index].date"></span>
            <h2 class="text-3xl font-black mt-2 mb-6 italic uppercase leading-none" x-text="posts[index].title"></h2>
            <div class="space-y-4 max-h-[60vh] overflow-y-auto pr-2 text-gray-700 leading-relaxed font-medium">
                <p x-text="posts[index].content"></p>
                <div class="bg-gray-50 p-6 rounded-3xl border-2 border-dashed border-gray-200">
                    <p class="text-xs font-black text-orange-600 uppercase italic mb-2">Thông tin chi tiết:</p>
                    <p class="text-sm text-gray-500 font-bold" x-text="posts[index].extra"></p>
                </div>
            </div>
            <button @click="showModal = false" class="mt-8 w-full py-4 bg-black text-white rounded-2xl font-black uppercase italic tracking-widest">ĐÓNG</button>
        </div>
    </div>

    <script>
        function zekaApp() {
            return {
                index: 0, showModal: false, fundValue: 3241000, fundDisplay: 0,
                posts: [
                    { date: "22/01/2026", title: "DEBUT QUỸ: MỞ CỔNG NHẬN DONATE", content: "Nhân dịp Zeka đạt được POM, thành lập quỹ nhỏ trên MoMo mua cheese donate stream.", extra: "Tên quỹ: Zeburger 🍔 | Donate for Zeka. Thủ quỹ: NGUYEN HONG XUAN NHUNG" },
                    { date: "28/01/2026", title: "Rút quỹ và Donate + Tổng kết tháng 1", content: "Rút quỹ sớm do đổi lịch stream. Tổng quỹ đến 28/01: 2.848.220 VNĐ.", extra: "Donate 50.000 phô mai (1.555.556đ) kèm lời chúc từ fan Việt Nam." },
                    { date: "27/02/2026", title: "Sự kiện 'Save for the BIG DAY'", content: "Tích lũy chuẩn bị kỷ niệm 6 năm Debut vào tháng 3.", extra: "Dư T1: 1.229.664đ + Thu T2: 1.948.336đ. Tổng khả dụng: 3.241.000đ." },
                    { date: "01/03/2026", title: "Debut trang Fanpage Chính Thức", content: "Chuyên nghiệp hóa hình ảnh Zeburger, ra mắt Fanpage cập nhật tin tức song song với X.", extra: "Hãy theo dõi Fanpage để đồng hành cùng chúng mình!" }
                ],
                init() {
                    let start = 0, duration = 2000;
                    let step = (timestamp) => {
                        if (!start) start = timestamp;
                        let progress = timestamp - start;
                        this.fundDisplay = Math.min(Math.floor((progress / duration) * this.fundValue), this.fundValue);
                        if (progress < duration) window.requestAnimationFrame(step);
                    };
                    window.requestAnimationFrame(step);
                },
                next() { this.index = (this.index + 1) % this.posts.length; },
                prev() { this.index = (this.index - 1 + this.posts.length) % this.posts.length; },
                openModal() { this.showModal = true; }
            }
        }
    </script>
</body>
</html>
